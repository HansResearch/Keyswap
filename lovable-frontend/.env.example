# Vite reads these at build time. VITE_* prefix → bundled into the JS sent to browsers.
# Copy to .env.local (local dev) or set as platform env vars (Railway / Vercel / Netlify dashboard).

# ⚠️ This RPC URL is shipped to every visitor's browser.
# Use a Helius key that's DOMAIN-RESTRICTED in the Helius dashboard (Allowed Origins → keyswap.fun)
# so it can't be abused from other sites if extracted from your JS bundle.
VITE_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_PUBLIC_DOMAIN_RESTRICTED_HELIUS_KEY

# The Solana program ID — public info, safe to ship.
VITE_PROGRAM_ID=983hyfdeswchDLV8epdLGHBCDwTVrkg8BGdxZv5pgMCf

# Backend URL — public. If left unset, frontend uses same-origin (recommended for
# production where backend is reverse-proxied at /api/*).
# VITE_BACKEND_URL=https://keyswap.fun
