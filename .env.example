# Used by the admin .mjs scripts at the repo root (init-protocol, propose-fee-destination, apply-fee-destination).
# Copy this file to .env, fill in real values, and source it before running scripts:
#   set -a; source .env; set +a; node init-protocol.mjs

# Mainnet program ID (set by `solana-keygen pubkey ~/.config/solana/keyswap-mainnet-program.json`)
PROGRAM_ID=983hyfdeswchDLV8epdLGHBCDwTVrkg8BGdxZv5pgMCf

# Solana RPC URL (Helius or similar — keep this PRIVATE, never commit the real value)
SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY_HERE
